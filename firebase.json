{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "target": "ownerdesk",
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          {"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"},
          {"key": "Pragma", "value": "no-cache"},
          {"key": "Expires", "value": "0"}
        ]
      },
      {
        "source": "**/*.js",
        "headers": [
          {"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"},
          {"key": "Pragma", "value": "no-cache"},
          {"key": "Expires", "value": "0"}
        ]
      },
      {
        "source": "**/*.css",
        "headers": [
          {"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  }
}
